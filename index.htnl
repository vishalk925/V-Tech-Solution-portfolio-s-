<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>V-Tech Solutions | Digital Growth Engine</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;800&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">

    <style>
        :root {
            --bg: #030508;
            --accent: #007AFF;
            --accent-light: #00C6FF;
            --accent-glow: rgba(0, 122, 255, 0.2);
            --glass: rgba(255, 255, 255, 0.02);
            --glass-border: rgba(255, 255, 255, 0.07);
            --text-main: #ffffff;
            --text-dim: #94a3b8;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Plus Jakarta Sans', sans-serif; scroll-behavior: smooth; }
        
        body { 
            background-color: var(--bg); 
            color: var(--text-main); 
            overflow-x: hidden;
            background-image: radial-gradient(circle at 2px 2px, rgba(255,255,255,0.02) 1px, transparent 0);
            background-size: 40px 40px;
        }

        .section-container { max-width: 1200px; margin: 120px auto; padding: 0 20px; }
        .btn-premium {
            background: linear-gradient(90deg, var(--accent), var(--accent-light));
            color: white; padding: 14px 32px; border-radius: 12px;
            text-decoration: none; font-weight: 700; display: inline-flex;
            align-items: center; gap: 10px; transition: 0.4s; border: none; cursor: pointer;
        }
        .btn-premium:hover { transform: translateY(-3px); box-shadow: 0 15px 30px var(--accent-glow); }

        /* --- Navigation --- */
        nav {
            position: fixed; top: 0; width: 100%; padding: 20px 5%;
            display: flex; justify-content: space-between; align-items: center;
            z-index: 1000; background: rgba(3, 5, 8, 0.8); backdrop-filter: blur(15px);
            border-bottom: 1px solid var(--glass-border);
        }
        .nav-logo img { height: 45px; filter: drop-shadow(0 0 5px var(--accent-glow)); }
        .nav-links a { color: var(--text-dim); text-decoration: none; margin-left: 30px; font-weight: 500; transition: 0.3s; }
        .nav-links a:hover { color: var(--accent-light); }

        /* --- Hero --- */
        .hero { height: 100vh; display: flex; align-items: center; justify-content: center; text-align: center; position: relative; }
        .hero h1 { font-size: clamp(2.5rem, 8vw, 5rem); font-weight: 800; line-height: 1.1; background: linear-gradient(to bottom, #fff, #888); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        .sphere { position: absolute; width: 500px; height: 500px; background: radial-gradient(circle, var(--accent-glow) 0%, transparent 70%); filter: blur(80px); z-index: -1; animation: float 10s infinite alternate; }

        /* --- Bento Services --- */
        .bento-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 50px; }
        .bento-card { background: var(--glass); border: 1px solid var(--glass-border); padding: 40px; border-radius: 32px; transition: 0.4s; }
        .bento-card:hover { border-color: var(--accent); background: rgba(255,255,255,0.05); }
        .span-2 { grid-column: span 2; }

        /* --- Pricing & Contact Form --- */
        .contact-form { background: var(--glass); padding: 40px; border-radius: 30px; border: 1px solid var(--glass-border); max-width: 600px; margin: 0 auto; }
        .contact-form input, .contact-form textarea {
            width: 100%; padding: 15px; background: rgba(255,255,255,0.03); border: 1px solid var(--glass-border);
            border-radius: 10px; color: white; margin-bottom: 20px; outline: none;
        }
        .contact-form input:focus { border-color: var(--accent); }

        @keyframes float { from { transform: translate(-10%, -10%); } to { transform: translate(10%, 10%); } }
        @media (max-width: 768px) { .bento-grid { grid-template-columns: 1fr; } .span-2 { grid-column: span 1; } .nav-links { display: none; } }
    </style>
</head>
<body>

    <nav>
        <div class="nav-logo"><img src="logo.png" alt="V-Tech Solutions"></div>
        <div class="nav-links">
            <a href="#home">Home</a>
            <a href="#services">Services</a>
            <a href="#ceo">Founder</a>
            <a href="#contact" class="btn-premium" style="padding: 8px 20px; font-size: 0.8rem;">Hire Us</a>
        </div>
    </nav>

    <section class="hero" id="home">
        <div class="sphere"></div>
        <div class="hero-content">
            <span style="color: var(--accent-light); letter-spacing: 4px; font-weight: 600; text-transform: uppercase;" data-aos="fade-down">Digital Growth Engine</span>
            <h1 data-aos="fade-up">Elite Tech Systems<br>by Vishal Sharma.</h1>
            <p style="color: var(--text-dim); margin: 30px 0; max-width: 600px; margin-inline: auto;" data-aos="fade-up" data-aos-delay="100">Web Development, Custom CRM, and Advanced Data Analysis.</p>
            <a href="#contact" class="btn-premium" data-aos="fade-up" data-aos-delay="200">Start Project</a>
        </div>
    </section>

    <section class="section-container" id="services">
        <h2 style="font-size: 2.5rem; text-align: center; margin-bottom: 50px;">Core Expertise</h2>
        <div class="bento-grid">
            <div class="bento-card span-2" data-aos="fade-right"><i data-lucide="terminal" color="#007AFF"></i><h3>Web Development</h3><p style="color: var(--text-dim);">Modern MERN stack applications.</p></div>
            <div class="bento-card" data-aos="fade-left"><i data-lucide="database" color="#007AFF"></i><h3>CRM Solutions</h3><p style="color: var(--text-dim);">Custom architecture for businesses.</p></div>
            <div class="bento-card" data-aos="fade-up"><i data-lucide="bar-chart" color="#007AFF"></i><h3>Data Analysis</h3><p style="color: var(--text-dim);">Actionable visual insights.</p></div>
            <div class="bento-card span-2" data-aos="fade-up"><i data-lucide="palette" color="#007AFF"></i><h3>Premium Branding</h3><p style="color: var(--text-dim);">Logo design and UI/UX identity.</p></div>
        </div>
    </section>

    <section class="section-container" id="ceo">
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 60px; align-items: center;">
            <div data-aos="fade-right" style="position: relative;">
                <div style="width: 100%; aspect-ratio: 1/1; background: #111; border-radius: 40px; border: 1px solid var(--glass-border); overflow: hidden;">
                    <img src="ceo-photo.jpg" alt="Vishal Sharma" style="width:100%; height:100%; object-fit:cover;">
                </div>
                <div style="position: absolute; bottom: -10px; right: -10px; background: var(--accent); padding: 15px; border-radius: 15px;">
                    <span style="font-weight: 800;">CEO & Founder</span>
                </div>
            </div>
            <div data-aos="fade-left">
                <h2 style="font-size: 3rem; margin-bottom: 20px;">Vishal Sharma</h2>
                <p style="color: var(--text-dim); font-size: 1.1rem; line-height: 1.8;">
                    "At V-Tech Solutions, we engineer digital engines that drive growth. My mission is to bridge the gap between complex data and elegant user experiences."
                </p>
                <div style="margin-top: 30px; display: flex; gap: 20px;">
                    <div style="border-left: 3px solid var(--accent); padding-left: 15px;"><b>Innovation</b><br><small>Modern Stacks</small></div>
                    <div style="border-left: 3px solid var(--accent); padding-left: 15px;"><b>Reliability</b><br><small>24/7 Support</small></div>
                </div>
            </div>
        </div>
    </section>

    <section class="section-container" id="contact">
        <div class="section-header" style="text-align: center; margin-bottom: 40px;">
            <h2>Work with V-Tech</h2>
            <p style="color: var(--text-dim);">Send a message directly to Vishal Sharma's team.</p>
        </div>
        <form action="https://formspree.io/f/YOUR_FORMSPREE_ID_HERE" method="POST" class="contact-form" data-aos="zoom-in">
            <input type="text" name="name" placeholder="Your Name" required>
            <input type="email" name="email" placeholder="Email Address" required>
            <textarea name="message" rows="5" placeholder="Project Details" required></textarea>
            <button type="submit" class="btn-premium" style="width: 100%; justify-content: center;">Send Inquiry</button>
        </form>
    </section>

    <footer style="padding: 60px 20px; text-align: center; border-top: 1px solid var(--glass-border);">
        <img src="logo.png" alt="V-Tech" style="height: 30px; opacity: 0.6; margin-bottom: 20px;">
        <p style="color: var(--text-dim); font-size: 0.8rem;">&copy; 2026 V-Tech Solutions | Vishal Sharma</p>
    </footer>

    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        lucide.createIcons();
        AOS.init({ duration: 1000, once: true });
        window.addEventListener('scroll', () => {
            const nav = document.querySelector('nav');
            nav.style.background = window.scrollY > 50 ? 'rgba(3, 5, 8, 0.95)' : 'rgba(3, 5, 8, 0.8)';
        });
    </script>
</body>
</html>
